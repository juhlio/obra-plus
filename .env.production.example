# ─────────────────────────────────────────────────────────────────────────────
# .env.production.example — Copie para .env no servidor e preencha os valores
# NUNCA commite o .env real no git
# ─────────────────────────────────────────────────────────────────────────────

# ── Aplicação ─────────────────────────────────────────────────────────────────
APP_NAME="Obra+"
APP_ENV=production
APP_KEY=                          # Gere com: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://seudominio.com
FRONTEND_URL=https://seudominio.com

# ── Banco de dados ────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=obraplus
DB_USERNAME=obraplus
DB_PASSWORD=SENHA_FORTE_AQUI
MYSQL_ROOT_PASSWORD=SENHA_ROOT_FORTE_AQUI

# ── E-mail (escolha um provedor) ──────────────────────────────────────────────
# Resend (recomendado — plano grátis 3k/mês): https://resend.com
MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=re_XXXXXXXXXXXXXXXX
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@seudominio.com
MAIL_FROM_NAME="Obra+"

# Mailgun (alternativa)
# MAIL_MAILER=mailgun
# MAILGUN_DOMAIN=seudominio.com
# MAILGUN_SECRET=key-XXXXXXXXXXXXXXXX

# ── Cache e sessão ────────────────────────────────────────────────────────────
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# ── SSL / Certbot ─────────────────────────────────────────────────────────────
DOMAIN=seudominio.com
CERTBOT_EMAIL=voce@seudominio.com

# App
# Nome da aplicação exibido na interface
APP_NAME="Obra+"

# Ambiente de execução: local | staging | production
APP_ENV=local

# Habilita/desabilita o modo debug (nunca true em produção)
APP_DEBUG=true

# URL base do backend Laravel
APP_URL=http://localhost:8000

# URL base do frontend React (usada no CORS e redirect)
FRONTEND_URL=http://localhost:5173

# Database
# Driver de banco de dados (mysql, pgsql, sqlite)
DB_CONNECTION=mysql

# Host do banco — use "db" para apontar ao container Docker
DB_HOST=db

# Porta do MySQL
DB_PORT=3306

# Nome do banco de dados
DB_DATABASE=

# Usuário do banco de dados
DB_USERNAME=

# Senha do usuário do banco de dados
DB_PASSWORD=

# Senha do usuário root do MySQL (usada somente no Docker)
MYSQL_ROOT_PASSWORD=
